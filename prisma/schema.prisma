generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model barang {
  id_barang           Int                   @id @default(autoincrement())
  kode_barang         String                @db.VarChar(50)
  nup                 String                @db.VarChar(20)
  kode_unik           String                @unique @db.VarChar(70)
  nama_barang         String                @db.VarChar(150)
  merek               String?               @db.VarChar(150)
  penguasaan          String?               @db.VarChar(50)
  tahun_perolehan     Int?
