  id_ruangan          Int?
  id_status           Int?
  created_by          Int?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  updated_at          DateTime?             @default(now()) @db.Timestamp(6)
  users               users?                @relation(fields: [created_by], references: [id_user], onDelete: NoAction, onUpdate: NoAction)
  ruangan             ruangan?              @relation(fields: [id_ruangan], references: [id_ruangan], onDelete: NoAction, onUpdate: NoAction)
  status_barang       status_barang?        @relation(fields: [id_status], references: [id_status], onDelete: NoAction, onUpdate: NoAction)
  detail_stock_opname detail_stock_opname[]
  laporan_kerusakan   laporan_kerusakan[]
  maintenance         maintenance[]
  pengajuan           pengajuan[]
  penghapusan         penghapusan[]
  qr_code             qr_code?
  riwayat_barang      riwayat_barang[]
}

